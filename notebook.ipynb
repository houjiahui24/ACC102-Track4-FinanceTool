# %%
import pandas as pd
import matplotlib.pyplot as plt

# 读取数据
df = pd.read_csv("wrds_data.csv")

# 基本信息
print(df.shape)
print(df['tic'].unique())

# %%
# 计算财务指标
df['roe'] = df['ni'] / df['ceq']
df['roa'] = df['ni'] / df['at']
df['pm'] = df['ni'] / df['sale']
df['lev'] = df['at'] / df['ceq']

print(df[['tic','fyear','roe','roa']].head())

# %%
# 画图
plt.figure(figsize=(10,4))

for tic in df['tic'].unique():
    c = df[df['tic'] == tic].sort_values('fyear')
    plt.plot(c['fyear'], c['roe'], marker='o', label=tic)

plt.title('ROE Trend')
plt.xlabel('Year')
plt.ylabel('ROE')
plt.legend()
plt.grid()
plt.show()
