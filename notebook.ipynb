# Track 4: Interactive Data Analysis Tool

# 1. Problem Definition
# Analyse ROE performance of Gree, Midea, Haier for investors.

# 2. Import libraries
import pandas as pd
import matplotlib.pyplot as plt

# 3. Data
data = {
    "Year": [2018,2019,2020,2021,2022,2023,2024],
    "Gree_ROE": [22.5,22.2,19.1,21.2,22.6,22.7,22.9],
    "Midea_ROE": [23.4,23.5,22.1,21.5,21.1,20.9,20.6],
    "Haier_ROE": [17.7,17.0,16.6,16.3,15.6,15.8,16.0]
}
df = pd.DataFrame(data)

# 4. Data cleaning
df = df.dropna()

# 5. Analysis
print("=== Key Findings ===")
print("Midea has highest ROE")
print("Gree is stable")
print("Haier steady but lower")

# 6. Visualisation
plt.figure(figsize=(10,5))
plt.plot(df.Year, df.Gree_ROE, label="Gree")
plt.plot(df.Year, df.Midea_ROE, label="Midea")
plt.plot(df.Year, df.Haier_ROE, label="Haier")
plt.title("ROE Comparison 2018–2024")
plt.legend()
plt.show()
