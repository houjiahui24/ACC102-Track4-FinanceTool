# For 1-minute presentation

import pandas as pd
import matplotlib.pyplot as plt

# Load the WRDS data we downloaded
df = pd.read_csv("wrds_data.csv")
df["fyear"] = df["fyear"].astype(int)

# Quick check of the data structure
print("Data loaded successfully")
print(df[["tic", "fyear", "sale", "ni", "at", "ceq"]].head())

# Calculate the 4 key financial ratios we need
df['roe'] = df['ni'] / df['ceq']
df['roa'] = df['ni'] / df['at']
df['pm'] = df['ni'] / df['sale']
df['lev'] = df['at'] / df['ceq']

# Plot ROE trend for the 4 companies
plt.figure(figsize=(6, 3))
for company in df["tic"].unique():
    subset = df[df["tic"] == company].sort_values("fyear")
    plt.plot(subset["fyear"], subset["roe"], marker='o', label=company)

plt.title("ROE Trend (2020-2024)")
plt.xlabel("Year")
plt.ylabel("ROE")
plt.legend()
plt.grid(alpha=0.3)
plt.show()

# Average performance summary
avg_performance = df.groupby("tic")[["roe", "roa", "pm", "lev"]].mean().round(3)
print("\nAverage financial indicators (2020-2024):")
print(avg_performance)
